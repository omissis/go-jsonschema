{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OneOfEnvelopeInvalid",
  "type": "object",
  "required": ["type", "value"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["a", "b"]
    },
    "value": {
      "title": "Payload",
      "type": "object",
      "x-go-oneof-envelope": {
        "discriminator": "type",
        "mapping": {
          "a": "AValue",
          "b": "BValue"
        }
      }
    }
  }
}
