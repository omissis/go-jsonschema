{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "id": "https://example.com/refToPrimitive",
  "type": "object",
  "properties": {
    "inlineThing": {
      "type": "string",
      "pattern": "^[a-z0-9.-]+$"
    },
    "refThing": {
      "$ref": "./thing.schema"
    }
  },
  "required": [
    "inlineThing",
    "refThing"
  ]
}
