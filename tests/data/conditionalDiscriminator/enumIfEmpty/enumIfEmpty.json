{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/enumIfEmpty",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string"
    },
    "details": {
      "type": "string"
    }
  },
  "required": [
    "kind"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "enum": []
          }
        }
      },
      "then": {
        "required": [
          "details"
        ]
      }
    }
  ]
}
