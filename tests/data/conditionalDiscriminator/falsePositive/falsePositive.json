{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/falsePositive",
  "type": "object",
  "properties": {
    "mode": {
      "type": "string",
      "enum": [
        "a",
        "b"
      ]
    },
    "extra": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "a"
          }
        }
      },
      "then": {
        "required": [
          "extra"
        ]
      }
    }
  ]
}
