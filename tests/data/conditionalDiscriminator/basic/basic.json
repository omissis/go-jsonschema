{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/basic",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "create",
        "update",
        "delete"
      ]
    },
    "id": {
      "type": "string"
    },
    "payload": {
      "type": "string"
    },
    "version": {
      "type": "integer"
    }
  },
  "required": [
    "kind"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "create"
          }
        }
      },
      "then": {
        "required": [
          "payload"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "update"
          }
        }
      },
      "then": {
        "required": [
          "id",
          "payload",
          "version"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "delete"
          }
        }
      },
      "then": {
        "required": [
          "id"
        ]
      }
    }
  ]
}
