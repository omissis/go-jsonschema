{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/enumIfWithExtraRequiredOnIf",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "a",
        "b"
      ]
    },
    "details": {
      "type": "string"
    }
  },
  "required": [
    "kind"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "enum": [
              "a",
              "b"
            ]
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "required": [
          "details"
        ]
      }
    }
  ]
}
