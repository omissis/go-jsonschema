{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "id": "https://example.com/strictShape",
  "type": "object",
  "properties": {
    "value": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "age":  { "type": "integer" }
          },
          "required": ["name"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "name":  { "type": "string" },
            "label": { "type": "string" }
          },
          "required": ["name"],
          "additionalProperties": false
        }
      ]
    }
  },
  "required": ["value"]
}
