{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "id": "https://example.com/primitiveDefs",
  "type": "object",
  "$defs": {
    "patternString": {
      "type": "string",
      "pattern": "^[a-z0-9.-]+$"
    },
    "boundedString": {
      "type": "string",
      "minLength": 3,
      "maxLength": 5
    },
    "constString": {
      "type": "string",
      "const": "stable"
    },
    "boundedInteger": {
      "type": "integer",
      "minimum": 1,
      "exclusiveMaximum": 10
    },
    "boundedNumber": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 10.5,
      "const": 3.5
    },
    "constBoolean": {
      "type": "boolean",
      "const": true
    }
  },
  "properties": {
    "inlinePatternString": {
      "type": "string",
      "pattern": "^[a-z0-9.-]+$"
    },
    "refPatternString": {
      "$ref": "#/$defs/patternString"
    },
    "inlineBoundedString": {
      "type": "string",
      "minLength": 3,
      "maxLength": 5
    },
    "refBoundedString": {
      "$ref": "#/$defs/boundedString"
    },
    "inlineConstString": {
      "type": "string",
      "const": "stable"
    },
    "refConstString": {
      "$ref": "#/$defs/constString"
    },
    "inlineBoundedInteger": {
      "type": "integer",
      "minimum": 1,
      "exclusiveMaximum": 10
    },
    "refBoundedInteger": {
      "$ref": "#/$defs/boundedInteger"
    },
    "inlineBoundedNumber": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 10.5,
      "const": 3.5
    },
    "refBoundedNumber": {
      "$ref": "#/$defs/boundedNumber"
    },
    "inlineConstBoolean": {
      "type": "boolean",
      "const": true
    },
    "refConstBoolean": {
      "$ref": "#/$defs/constBoolean"
    },
    "legacyNullableBoundedString": {
      "$ref": "#/$defs/boundedString"
    }
  },
  "required": [
    "inlinePatternString",
    "refPatternString",
    "inlineBoundedString",
    "refBoundedString",
    "inlineConstString",
    "refConstString",
    "inlineBoundedInteger",
    "refBoundedInteger",
    "inlineBoundedNumber",
    "refBoundedNumber",
    "inlineConstBoolean",
    "refConstBoolean"
  ]
}
