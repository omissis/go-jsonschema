{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/canonical/v1/canonical-fragment.json",
  "type": "object",
  "$defs": {
    "JobPriority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "Envelope": {
      "type": "object",
      "properties": {
        "messageId": {
          "type": "string"
        }
      },
      "required": [
        "messageId"
      ]
    }
  }
}
